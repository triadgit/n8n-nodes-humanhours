{
	"name": "n8n-nodes-humanhours",
	"version": "0.1.0",
	"description": "n8n community node for humanhours. Track AI agent tasks straight from your workflows; humanhours computes hours and euros saved.",
	"license": "MIT",
	"homepage": "https://humanhours.dev",
	"keywords": [
		"n8n-community-node-package",
		"n8n-nodes",
		"humanhours",
		"ai",
		"agents",
		"observability",
		"roi"
	],
	"author": {
		"name": "Ralf Klein",
		"email": "ralf@triad.nl"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/triadgit/n8n-nodes-humanhours.git"
	},
	"bugs": {
		"url": "https://github.com/triadgit/n8n-nodes-humanhours/issues"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/HumanhoursApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Humanhours/Humanhours.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
